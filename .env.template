# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=aeprofile
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aeprofile

# LLM Provider Configuration
# Set LLM_PROVIDER to "gemini", "vllm", "openai", or "ollama"
LLM_PROVIDER=gemini
LLM_MODEL=llama3

# Gemini Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.1-flash-lite

# vLLM / OpenAI-compatible Configuration
# Use this when LLM_PROVIDER is set to "vllm"
VLLM_API_BASE=http://localhost:8000/v1
VLLM_API_KEY=your_vllm_api_key_or_empty
VLLM_MODEL=your_vllm_model_name

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1
